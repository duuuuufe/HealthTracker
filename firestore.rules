rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Helpers
    // ─────────────────────────────────────────────────────────────
    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────────────────────
    // User profile + all owned subcollections
    // ─────────────────────────────────────────────────────────────
    // /users/{uid}                 → user profile doc
    // /users/{uid}/medications/*
    // /users/{uid}/appointments/*
    // /users/{uid}/notes/*
    // /users/{uid}/contacts/*
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /{subcollection}/{docId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─────────────────────────────────────────────────────────────
    // Vitals (global collection — each doc has a userId field)
    // Rules ensure a user can only read/modify rows they own, and
    // can only create rows that set themselves as the owner.
    // ─────────────────────────────────────────────────────────────
    match /vitals/{docId} {
      allow read, update, delete:
        if signedIn() && resource.data.userId == request.auth.uid;
      allow create:
        if signedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ─────────────────────────────────────────────────────────────
    // Default deny — any path not matched above is rejected
    // ─────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
